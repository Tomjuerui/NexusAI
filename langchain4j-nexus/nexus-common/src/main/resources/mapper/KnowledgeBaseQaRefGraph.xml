<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyz.nexus.common.mapper.KnowledgeBaseQaRecordRefGraphMapper">
    <select id="listByQaUuid" resultType="com.moyz.nexus.common.entity.KnowledgeBaseQaRefGraph">
        select *
        from nexus_knowledge_base_qa_ref_graph a
                 inner join nexus_knowledge_base_qa b on a.qa_record_id = b.id
        where b.uuid = #{qaUuid}
    </select>

</mapper>
