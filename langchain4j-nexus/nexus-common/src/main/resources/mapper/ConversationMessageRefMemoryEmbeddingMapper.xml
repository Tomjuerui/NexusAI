<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyz.nexus.common.mapper.ConversationMessageRefMemoryEmbeddingMapper">
    <select id="listByMsgUuid" resultType="com.moyz.nexus.common.entity.ConversationMessageRefMemoryEmbedding">
        select *
        from nexus_conversation_message_ref_memory_embedding a
                 inner join nexus_conversation_message b on a.message_id = b.id
        where b.uuid = #{uuid}
    </select>
</mapper>
